# ============================================================
# ELEVE IMPORTS — Variáveis de Ambiente
# ============================================================
# Copie para .env e preencha os valores reais.
# Nuxt sobrescreve runtimeConfig via prefixo NUXT_ automaticamente.
# ============================================================

# -- Appwrite (servidor/privado — não exposto ao cliente) --
NUXT_APPWRITE_API_KEY=
NUXT_APPWRITE_ENDPOINT=https://sistemas-appwrite.oczois.easypanel.host/
NUXT_APPWRITE_PROJECT_ID=69cd7caa001df667ead9

# -- Appwrite (público — exposto ao client-side) --
NUXT_PUBLIC_APPWRITE_ENDPOINT=https://sistemas-appwrite.oczois.easypanel.host/
NUXT_PUBLIC_APPWRITE_PROJECT_ID=69cd7caa001df667ead9

# -- Site --
NUXT_PUBLIC_SITE_URL=https://eleveimports.com

# -- Ambiente --
NODE_ENV=production
